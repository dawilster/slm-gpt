<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Menubar accessory app — no Dock icon, no entry in ⌘-Tab, no app menu.
	  Runtime also calls NSApp.setActivationPolicy(.accessory); this key
	  ensures it's true from the very first frame so the icon never flashes.
	-->
	<key>LSUIElement</key>
	<true/>

	<!--
	  Local-network ATS exception so the sandboxed app can talk to the
	  Halo runtime daemon over plain HTTP at 127.0.0.1.
	  Only loopback is exempted; public HTTP remains blocked.
	-->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
</dict>
</plist>
